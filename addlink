<div class="card"> 
    <div>
        <!-- ส่วนแสดงไอคอน (เปลี่ยน Emoji ได้ตามต้องการ) -->
        <span class="card-icon">🚀</span> 

        <!-- ชื่อเครื่องมือ: data-key คือ "รหัส" ที่จะไปดึงข้อความจาก JavaScript -->
        <h3 data-key="web5_t">ชื่อเว็บใหม่</h3> 

        <!-- คำอธิบาย: data-key ต้องตั้งชื่อให้สื่อความหมาย (เช่น d = description) -->
        <p data-key="web5_d">คำอธิบายเว็บใหม่</p>
    </div>

    <!-- ปุ่มกด: ใส่ลิงก์เว็บของคุณที่ href="..." และใช้ data-key="btn_text" เพื่อให้เปลี่ยนภาษาได้ -->
    <a href="URL_ของเว็บคุณ" class="btn-open" data-key="btn_text">เปิดใช้งาน</a>
</div>
